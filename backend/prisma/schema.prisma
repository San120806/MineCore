// ─────────────────────────────────────────────────────────────────────────────
// MineCore — Smart Mining Operations Platform
// Prisma Schema — Phase 2: Database Design
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  OPERATIONS_MANAGER
  SAFETY_OFFICER
  MAINTENANCE_ENGINEER
}

enum SiteStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  DECOMMISSIONED
}

enum VehicleType {
  DUMP_TRUCK
  EXCAVATOR
  DRILL_RIG
  LOADER
  DOZER
  HAUL_TRUCK
}

enum VehicleStatus {
  ACTIVE
  IDLE
  MAINTENANCE
  OFFLINE
}

enum SensorType {
  TEMPERATURE
  PRESSURE
  VIBRATION
  AIR_QUALITY
  HUMIDITY
}

enum SensorStatus {
  ONLINE
  OFFLINE
  DEGRADED
  CALIBRATING
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum EquipmentType {
  CONVEYOR
  CRUSHER
  PUMP
  COMPRESSOR
  GENERATOR
  DRILL
}

enum EquipmentStatus {
  OPERATIONAL
  DEGRADED
  OFFLINE
  DECOMMISSIONED
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  PREDICTIVE
  EMERGENCY
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String   @db.VarChar(255)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole @default(OPERATIONS_MANAGER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  raisedAlerts   SafetyAlert[]      @relation("RaisedByUser")
  resolvedAlerts SafetyAlert[]      @relation("ResolvedByUser")
  maintenanceDone MaintenanceRecord[] @relation("PerformedByUser")

  @@index([email])
  @@index([role])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// MINING SITE
// ─────────────────────────────────────────────────────────────────────────────

model MiningSite {
  id          String     @id @default(uuid())
  name        String     @db.VarChar(255)
  location    String     @db.VarChar(500)
  coordinates String?    @db.VarChar(100)  // "lat,lng" string format
  status      SiteStatus @default(ACTIVE)
  areaSqKm    Float?     @map("area_sq_km")
  workerCount Int        @default(0) @map("worker_count")
  managerName String?    @map("manager_name") @db.VarChar(255)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relations
  vehicles     Vehicle[]
  sensors      Sensor[]
  equipment    Equipment[]
  safetyAlerts SafetyAlert[]

  @@index([status])
  @@index([name])
  @@map("mining_sites")
}

// ─────────────────────────────────────────────────────────────────────────────
// VEHICLE
// ─────────────────────────────────────────────────────────────────────────────

model Vehicle {
  id           String        @id @default(uuid())
  siteId       String        @map("site_id")                         // FK → MiningSite
  vehicleCode  String        @unique @map("vehicle_code") @db.VarChar(50)  // e.g. VH-001
  name         String        @db.VarChar(255)
  model        String        @db.VarChar(255)
  serialNumber String        @unique @map("serial_number") @db.VarChar(100)
  type         VehicleType
  status       VehicleStatus @default(IDLE)
  fuelLevel    Float         @default(100.0) @map("fuel_level")    // 0–100 percentage
  batteryLevel Float?        @map("battery_level")                  // 0–100, null for non-electric
  lastLocation String?       @map("last_location") @db.VarChar(100) // "lat,lng"
  lastSeen     DateTime?     @map("last_seen")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  // Relations
  site MiningSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([status])
  @@index([type])
  @@index([vehicleCode])
  @@index([serialNumber])
  @@map("vehicles")
}

// ─────────────────────────────────────────────────────────────────────────────
// SENSOR
// ─────────────────────────────────────────────────────────────────────────────

model Sensor {
  id           String       @id @default(uuid())
  siteId       String       @map("site_id")                          // FK → MiningSite (spec: miningSiteId)
  sensorCode   String       @unique @map("sensor_code") @db.VarChar(50) // e.g. SN-001
  name         String       @db.VarChar(255)
  sensorType   SensorType   @map("sensor_type")                      // spec: sensorType
  status       SensorStatus @default(ONLINE)
  value        Float?                                                  // spec: value (current reading)
  unit         String       @db.VarChar(50)  // e.g. "°C", "hPa", "m/s²", "ppm", "%"
  thresholdMin Float?       @map("threshold_min")
  thresholdMax Float?       @map("threshold_max")
  lastReading  DateTime?    @map("last_reading")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")             // spec: updatedAt

  // Relations
  site     MiningSite      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  readings SensorReading[]

  @@index([siteId])
  @@index([sensorType])
  @@index([status])
  @@index([sensorCode])
  @@map("sensors")
}

// ─────────────────────────────────────────────────────────────────────────────
// SENSOR READING  (time-series data)
// ─────────────────────────────────────────────────────────────────────────────

model SensorReading {
  id         String   @id @default(uuid())
  sensorId   String   @map("sensor_id")
  value      Float
  unit       String   @db.VarChar(50)
  recordedAt DateTime @default(now()) @map("recorded_at")

  // Relations
  sensor Sensor @relation(fields: [sensorId], references: [id], onDelete: Cascade)

  @@index([sensorId])
  @@index([recordedAt])
  @@index([sensorId, recordedAt])  // Composite for time-range queries
  @@map("sensor_readings")
}

// ─────────────────────────────────────────────────────────────────────────────
// SAFETY ALERT
// ─────────────────────────────────────────────────────────────────────────────

model SafetyAlert {
  id           String        @id @default(uuid())
  siteId       String        @map("site_id")
  raisedById   String        @map("raised_by_id")
  resolvedById String?       @map("resolved_by_id")
  title        String        @db.VarChar(255)
  description  String        @db.Text
  severity     AlertSeverity
  status       AlertStatus   @default(OPEN)
  location     String?       @db.VarChar(255) // Free-text location within site
  raisedAt     DateTime      @default(now()) @map("raised_at")
  resolvedAt   DateTime?     @map("resolved_at")

  // Relations
  site       MiningSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  raisedBy   User       @relation("RaisedByUser", fields: [raisedById], references: [id])
  resolvedBy User?      @relation("ResolvedByUser", fields: [resolvedById], references: [id])

  @@index([siteId])
  @@index([severity])
  @@index([status])
  @@index([raisedAt])
  @@index([siteId, status])  // Common combined filter
  @@map("safety_alerts")
}

// ─────────────────────────────────────────────────────────────────────────────
// EQUIPMENT
// ─────────────────────────────────────────────────────────────────────────────

model Equipment {
  id                  String          @id @default(uuid())
  siteId              String          @map("site_id")              // FK → MiningSite (spec: miningSiteId)
  name                String          @db.VarChar(255)
  model               String          @db.VarChar(255)
  serialNumber        String          @unique @map("serial_number") @db.VarChar(100)
  type                EquipmentType
  status              EquipmentStatus @default(OPERATIONAL)
  healthScore         Int             @default(100) @map("health_score")        // spec: 0–100
  nextMaintenanceDate DateTime?       @map("next_maintenance_date")             // spec: nextMaintenanceDate
  lastInspected       DateTime?       @map("last_inspected")
  installedAt         DateTime?       @map("installed_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  // Relations
  site               MiningSite         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  maintenanceRecords MaintenanceRecord[]

  @@index([siteId])
  @@index([status])
  @@index([type])
  @@index([healthScore])
  @@index([nextMaintenanceDate])
  @@map("equipment")
}

// ─────────────────────────────────────────────────────────────────────────────
// MAINTENANCE RECORD
// ─────────────────────────────────────────────────────────────────────────────

model MaintenanceRecord {
  id              String            @id @default(uuid())
  equipmentId     String            @map("equipment_id")            // spec: equipmentId
  performedById   String?           @map("performed_by_id")
  issue           String            @db.VarChar(500)                // spec: issue
  actionTaken     String?           @map("action_taken") @db.Text   // spec: actionTaken
  maintenanceDate DateTime          @map("maintenance_date")        // spec: maintenanceDate
  type            MaintenanceType
  status          MaintenanceStatus @default(SCHEDULED)
  scheduledAt     DateTime?         @map("scheduled_at")            // extended: future-scheduling
  completedAt     DateTime?         @map("completed_at")
  notes           String?           @db.Text
  cost            Float?            // Actual cost in USD
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  // Relations
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  performedBy User?     @relation("PerformedByUser", fields: [performedById], references: [id])

  @@index([equipmentId])
  @@index([status])
  @@index([type])
  @@index([maintenanceDate])
  @@index([equipmentId, status])  // Common combined filter
  @@map("maintenance_records")
}
